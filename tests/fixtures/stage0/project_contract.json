  "forbidden_proxies": [
    {
      "id": "fp-01",
      "subject": "claim-benchmark",
      "proxy": "qualitative trend match without numerical comparison",
      "reason": "Would allow false progress without testing the decisive benchmark"
    }
  ],
  "links": [
    {
      "id": "link-01",
      "source": "deliv-figure",
      "target": "claim-benchmark",
      "relation": "supports",
      "verified_by": [
        "test-benchmark"
      ]
    }
  ],
  "uncertainty_markers": {
    "weakest_anchors": [
      "Reference tolerance interpretation"
    ],
    "unvalidated_assumptions": [
      "Current preprocessing preserves the observable definition"
    ],
    "competing_explanations": [
      "Agreement could be a normalization artifact"
    ],
    "disconfirming_observations": [
      "Benchmark agreement disappears once normalization is fixed"
