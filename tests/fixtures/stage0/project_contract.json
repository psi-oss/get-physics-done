  "claims": [
    {
      "id": "claim-benchmark",
      "statement": "Recover the benchmark value within tolerance",
      "observables": [
        "obs-benchmark"
      ],
      "deliverables": [
        "deliv-figure"
      ],
      "acceptance_tests": [
        "test-benchmark"
      ],
      "references": [
        "ref-benchmark"
      ]
    }
  ],
  "deliverables": [
    {
      "id": "deliv-figure",
