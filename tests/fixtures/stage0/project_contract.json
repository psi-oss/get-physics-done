        "baseline curve",
        "error bars"
      ]
    }
  ],
  "acceptance_tests": [
    {
      "id": "test-benchmark",
      "subject": "claim-benchmark",
      "kind": "benchmark",
      "procedure": "Compare against the benchmark reference",
      "pass_condition": "Matches reference within tolerance",
      "evidence_required": [
        "deliv-figure",
        "ref-benchmark"
      ],
      "automation": "hybrid"
    }
  ],
  "references": [
    {
      "id": "ref-benchmark",
      "kind": "paper",
      "locator": "Author et al., Journal, 2024",
      "role": "benchmark",
      "why_it_matters": "Published comparison target",
      "applies_to": [
        "claim-benchmark"
      ],
      "must_surface": true,
      "required_actions": [
        "read",
        "compare",
        "cite"
