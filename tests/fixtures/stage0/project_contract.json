      "primary benchmark comparison"
    ],
    "out_of_scope": [
      "adjacent publication tasks"
    ],
    "unresolved_questions": [
      "Which diagnostic artifact should be primary?"
    ]
  },
  "context_intake": {
    "must_read_refs": [
      "ref-benchmark"
    ],
    "must_include_prior_outputs": [
      ".gpd/phases/01-setup/01-01-SUMMARY.md"
    ],
    "user_asserted_anchors": [
      "Recover known limiting behavior"
    ],
    "known_good_baselines": [
      "Baseline notebook A"
    ],
    "context_gaps": [
      "Missing benchmark table"
    ],
    "crucial_inputs": [
      "Figure 2 from prior work"
    ]
  },
  "observables": [
    {
      "id": "obs-benchmark",
      "name": "benchmark observable",
      "kind": "scalar",
      "definition": "Primary observable compared against literature"
