{
  "project_reference": {
    "project_md_updated": null,
    "core_research_question": "Can ML-optimized modular-bootstrap searches in the finite-central-charge window 1 < c <= 8/7 reproduce or sharpen the established Virasoro gap constraints without overclaiming exact CFT existence?",
    "current_focus": "Phase 01: Literature and contract anchoring"
  },
  "project_contract": {
    "schema_version": 1,
    "scope": {
      "question": "Can machine-learning-style optimization identify trustworthy finite-central-charge Virasoro modular-bootstrap solutions in the window 1 < c <= 8/7 and sharpen the near-c=1 spectral-gap story without overclaiming CFT existence?",
      "in_scope": [
        "Track the finite-c Virasoro modular-bootstrap benchmark literature from 2013 through 2026",
        "Compare classic SDP, fast truncation, integrality, geometric, and ML-optimized modular-bootstrap constraints in a single convention set",
        "Treat finite c as finite central charge and keep the torus-partition-function problem explicitly 2d and Virasoro based",
        "Define evidence standards for candidate spectra, truncation uncertainty, and gap-bound improvement claims"
      ],
      "out_of_scope": [
        "Claiming a rigorous proof that the ML-generated candidate spectra correspond to exact new CFTs",
        "Exploring non-Virasoro chiral algebras, mixed-correlator crossing systems, or large-c holographic limits as the primary target",
        "Running a full production numerical scan or SDPB campaign in this workspace during the initialization pass"
      ],
      "unresolved_questions": [
        "Which diagnostics best separate genuine nearby CFT solutions from optimizer artifacts in the 1 < c <= 8/7 window?",
        "How much of the near-c=1 gap improvement survives once truncation and integrality systematics are combined?",
        "Can the continuous family suggested by the 2026 ML paper be constrained further by analytic or geometric bootstrap input?"
      ]
    },
    "context_intake": {
      "must_read_refs": [
        "Ref-2013-FK",
        "Ref-2016-CLY",
        "Ref-2019-AJT",
        "Ref-2023-FL-Integrality",
        "Ref-2023-Geometry",
        "Ref-2026-BFLT"
      ],
      "must_include_prior_outputs": [
        "GPD/literature/finite-c-modular-bootstrap.md",
        "GPD/phases/04-candidate-spectrum-and-gap-constraint-synthesis/benchmark-gap-comparison.md",
        "GPD/phases/05-validation-uncertainties-and-continuation-plan/ml-diagnostics-checklist.md"
      ],
      "user_asserted_anchors": [
        "GPD/PROJECT.md",
        "journal.md"
      ],
      "known_good_baselines": [
        "GPD/literature/finite-c-modular-bootstrap.md",
        "GPD/phases/04-candidate-spectrum-and-gap-constraint-synthesis/benchmark-gap-comparison.md",
        "GPD/phases/05-validation-uncertainties-and-continuation-plan/ml-diagnostics-checklist.md"
      ],
      "context_gaps": [
        "No local numerical pipeline or reproduced spectra are present yet",
        "No decisive benchmark figure has been regenerated inside this workspace yet"
      ],
      "crucial_inputs": [
        "Virasoro torus partition function modular invariance",
        "Spectral-gap observable Delta_gap(c)",
        "Truncation-uncertainty diagnostics in ML-optimized searches",
        "Integrality and geometric constraints as non-ML cross-checks"
      ]
    },
    "approach_policy": {
      "formulations": [
        "Virasoro modular bootstrap for unitary compact 2d CFTs with c > 1",
        "Finite-c benchmark comparison centered on 1 < c <= 8/7",
        "ML-style loss minimization treated as a search heuristic, not as proof by itself"
      ],
      "allowed_estimator_families": [
        "semi-definite-program gap bounds",
        "finite polynomial truncation diagnostics",
        "integrality-enhanced modular-bootstrap bounds",
        "loss-minimization over truncated spectra with explicit uncertainty estimates"
      ],
      "forbidden_estimator_families": [
        "qualitative candidate-spectrum matches without modular-residual or truncation diagnostics",
        "claims of new CFT existence based only on low loss at one truncation depth",
        "comparisons that mix inconsistent conventions for central charge, gap definition, or partition-function normalization"
      ],
      "allowed_fit_families": [
        "benchmark-by-benchmark comparison against published gap curves and candidate spectra",
        "uncertainty-aware local interpolation in c when reproducing published scans"
      ],
      "forbidden_fit_families": [
        "smooth extrapolations beyond the validated c window without source support",
        "fits chosen only for visual agreement with no literature anchor"
      ],
      "stop_and_rethink_conditions": [
        "A result appears stronger than arXiv:2604.01275 but rests on weaker truncation control than that paper reports",
        "A claimed finite-c improvement disappears after aligning conventions with arXiv:1608.06241 or arXiv:2308.08725",
        "Candidate spectra look plausible but fail integrality or geometric consistency checks"
      ]
    },
