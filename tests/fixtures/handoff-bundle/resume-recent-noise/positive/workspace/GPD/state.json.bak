  "project_contract": {
    "schema_version": 1,
    "scope": {
      "question": "Does DSSYK have a semiclassical de Sitter bulk dual, and if so is it a full bulk dual or only a constrained-sector correspondence?",
      "in_scope": [
        "Audit the semiclassical evidence connecting DSSYK correlators and thermodynamics to candidate de Sitter bulk descriptions.",
        "Distinguish a full semiclassical bulk dual from a correlator-only or sector-restricted match."
      ],
      "out_of_scope": [
        "Constructing a new microscopic bulk theory beyond the candidate models already in the literature.",
        "Numerical simulations of finite-N SYK outside the analytic double-scaled regime."
      ],
      "unresolved_questions": [
        "Is the doubled equal-energy constrained system the decisive notion of DSSYK relevant to the bulk-dual question, or only one auxiliary sector?",
        "Can fake temperature be given a genuinely smooth semiclassical bulk interpretation without introducing a proxy notion of thermality?"
      ]
    },
    "context_intake": {
      "must_read_refs": [
        "Ref-2209-09997",
        "Ref-2310-16994",
        "Ref-2402-02584",
        "Ref-2404-03535"
      ],
      "must_include_prior_outputs": [],
      "user_asserted_anchors": [],
      "known_good_baselines": [
        "The correlator match claimed in arXiv:2310.16994 and arXiv:2402.02584 must be reproduced faithfully before broader verdicts are drawn."
      ],
      "context_gaps": [
        "No single paper yet establishes both the correlator match and an uncontested semiclassical interpretation of temperature, entropy, and operator dictionary."
      ],
      "crucial_inputs": [
        "A final report that classifies the status of the semiclassical bulk-dual claim as full, sector-restricted, or unsupported.",
        "A comparison of correlator evidence against thermal and geometric consistency checks."
      ]
    },
    "approach_policy": {
      "formulations": [
        "Compare doubled/infinite-temperature DSSYK constructions directly against dS JT, Liouville-de Sitter, sine dilaton, and related reduced 3D de Sitter descriptions."
      ],
      "allowed_estimator_families": [
        "Exact literature formulas for DSSYK correlators and spectra.",
        "Semiclassical bulk Green's functions and thermodynamic dictionaries stated in the anchor papers."
      ],
      "forbidden_estimator_families": [
        "Proxy-only arguments that rely on qualitative chaos or scrambling analogies without matching the decisive observables.",
        "Claims of bulk emergence that ignore the equal-energy constraint or fake-temperature subtlety."
      ],
      "allowed_fit_families": [
        "Direct side-by-side comparison of candidate bulk observables and boundary formulas."
      ],
      "forbidden_fit_families": [
        "Broad de Sitter-holography rhetoric without checking the concrete DSSYK dictionaries."
      ],
      "stop_and_rethink_conditions": [
        "If the strongest evidence remains a correlator match in a constrained sector while the thermal interpretation and bulk operator map stay inconsistent, do not upgrade the claim to a full semiclassical bulk dual."
      ]
    },
