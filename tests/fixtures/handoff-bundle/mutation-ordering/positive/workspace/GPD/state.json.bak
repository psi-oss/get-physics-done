{
  "project_reference": {
    "project_md_updated": "2026-04-09",
    "core_research_question": "Can rQFC be reformulated and justified beyond braneworld holographic semiclassical gravity without losing the benchmark consequences already established in the literature?",
    "current_focus": "Phase 01 benchmark ingredient ledger and comparison setup"
  },
  "project_contract": {
    "schema_version": 1,
    "scope": {
      "question": "Can the restricted quantum focusing conjecture be extended beyond braneworld semiclassical gravity, and what minimal assumptions are sufficient?",
      "in_scope": [
        "Map non-braneworld settings where rQFC is already tested or plausibly provable",
        "Isolate the model-independent ingredients behind the braneworld proof",
        "Formulate a candidate extension strategy that matches known JT-gravity and d>2 consequences"
      ],
      "out_of_scope": [
        "A full proof of the unrestricted QFC in arbitrary semiclassical gravity",
        "Numerical checks unrelated to null deformations or generalized entropy"
      ],
      "unresolved_questions": [
        "Which ingredients of the braneworld proof are indispensable rather than holographic conveniences?",
        "What replaces higher-dimensional Einstein-dual control in generic non-braneworld settings?"
      ]
    },
    "context_intake": {
      "must_read_refs": [
        "Ref-rqfc",
        "Ref-inec",
        "Ref-tests"
      ],
      "must_include_prior_outputs": [],
      "user_asserted_anchors": [
        "arXiv:2212.03881",
        "arXiv:2310.14396",
        "arXiv:2510.13961"
      ],
      "known_good_baselines": [
        "arXiv:2212.03881"
      ],
      "context_gaps": [
        "Need a precise non-braneworld formulation of the entropy-variation data required by the proof strategy"
      ],
      "crucial_inputs": [
        "The braneworld proof structure in arXiv:2212.03881",
        "The Theta -> 0 improved-energy-condition limit in arXiv:2310.14396",
        "The JT-gravity and d>2 tests in arXiv:2510.13961"
      ]
    },
    "approach_policy": {
      "formulations": [
        "Null-deformation analysis of generalized entropy and quantum expansion",
        "Comparison between braneworld, JT-gravity, and generic QFT/CFT formulations"
      ],
      "allowed_estimator_families": [
        "Analytic reduction to QNEC- or entropy-variation inequalities",
        "Model-by-model comparison against published proofs and counterexamples"
      ],
      "forbidden_estimator_families": [
        "Pure analogy to holography without checking entropy-functional control",
        "Claims based only on unrestricted-QFC intuition after explicit counterexamples"
      ],
      "allowed_fit_families": [
        "Minimal-assumption classification of proof ingredients"
      ],
      "forbidden_fit_families": [
        "Ad hoc generalization that does not reproduce known benchmark cases"
      ],
      "stop_and_rethink_conditions": [
        "A proposed extension cannot recover the braneworld proof ingredients or conflicts with the JT-gravity tests",
        "The strategy relies on assumptions already falsified by counterexamples to the stronger QFC"
      ]
    },
