    "scope": {
      "in_scope": [
        "Benchmark the Antonini-Sasieta-Swingle random-entanglement cosmology against established holographic singularity papers",
        "Identify boundary observables based on entanglement, quantum extremal surfaces, or complexity that could diagnose the singular region",
        "Separate claims of singularity avoidance, singularity resolution, and diagnostic blindness"
      ],
      "out_of_scope": [
        "Numerical quantum gravity resolution of the singularity",
        "Phenomenological cosmology or observational data fitting",
        "Claiming a microscopic CFT Hamiltonian realization unless the literature provides one"
      ],
      "question": "Can entangled multi-CFT states produce or diagnose cosmological singularities in a way that is sharper than existing Kasner-like holographic probes?",
      "unresolved_questions": [
        "Which boundary observable, if any, can distinguish the entangled-CFT cosmology from generic Kasner-like singularity avoidance?",
        "Does the Antonini construction imply resolution of the singularity or only an emergent semiclassical cosmological patch?"
      ]
    },
    "uncertainty_markers": {
      "competing_explanations": [
        "The entangled-CFT construction may encode only a coarse-grained semiclassical patch rather than a resolved singular geometry",
        "Observed extremal-surface avoidance may be universal and therefore non-diagnostic of genuine resolution"
      ],
      "disconfirming_observations": [
        "If every benchmark observable shows only the same avoidance behaviour found in earlier Kasner-like papers, the project cannot claim new singularity resolution from entanglement alone"
      ],
      "unvalidated_assumptions": [
        "Random-entanglement states faithfully capture a microscopic holographic CFT sector relevant for cosmological singularities"
      ],
      "weakest_anchors": [
        "No decisive boundary observable yet separates singularity resolution from singularity avoidance in the Antonini construction"
      ]
    }
