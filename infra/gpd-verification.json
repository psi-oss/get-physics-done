{
  "name": "gpd-verification",
  "description": "GPD physics verification checks. Tools for running dimensional analysis, limiting case checks, symmetry verification, and coverage gap analysis.",
  "transport": "stdio",
  "command": "python",
  "args": [
    "-m",
    "gpd.mcp.servers.verification_server"
  ],
  "env": {
    "LOG_LEVEL": "${LOG_LEVEL:-WARNING}"
  },
  "capabilities": [
    "run_check",
    "get_checklist",
    "dimensional_check",
    "limiting_case_check",
    "symmetry_check",
    "get_verification_coverage"
  ],
  "registry_prefix": "gpd_verification",
  "prerequisites": [
    "Install GPD first: npx -y get-physics-done"
  ],
  "health_check": {
    "tool": "get_checklist",
    "input": {
      "domain": "qft"
    },
    "expect": "contains Ward identities"
  },
  "alternatives": {
    "entry_point": {
      "command": "gpd-mcp-verification",
      "args": [],
      "notes": "Requires gpd package installed"
    }
  }
}
