    "hook_payload": {
      "workspace_keys": ["cwd", "current_dir", "path", "workspace_dir"],
      "project_dir_keys": ["project_dir"],
      "target_path_keys": ["target_path"],
      "target_root_keys": ["target_root"],
      "model_keys": ["display_name", "name", "id"],
      "context_window_size_keys": ["context_window_size"],
      "context_remaining_keys": ["remaining_percentage", "remainingPercent", "remaining"]
    },
    "managed_install_surface": {
      "nested_command_globs": ["commands/gpd/**/*"]
    },
    "global_config": {
      "strategy": "env_or_home",
      "env_var": "CLAUDE_CONFIG_DIR",
      "home_subpath": ".claude"
    }
