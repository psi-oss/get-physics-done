{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PhysicsPayloadOverlay",
  "description": "Physics domain overlay for StateV2 payload.\n\nAdds physics-specific fields to the base payload: convention tracking,\napproximation management, intermediate results, open questions,\nactive calculations, decisions, pending todos, blockers,\npropagated uncertainties, and GPD position tracking.\n\nApplied on top of StateV2.json via schema merge (base has additionalProperties: true).",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "convention_lock": {
      "type": "object",
      "description": "Tracks locked physics conventions — 18 named fields matching ConventionLock plus custom.",
      "properties": {
        "metric_signature": {"type": ["string", "null"]},
        "fourier_convention": {"type": ["string", "null"]},
        "natural_units": {"type": ["string", "null"]},
        "gauge_choice": {"type": ["string", "null"]},
        "regularization_scheme": {"type": ["string", "null"]},
        "renormalization_scheme": {"type": ["string", "null"]},
        "coordinate_system": {"type": ["string", "null"]},
        "spin_basis": {"type": ["string", "null"]},
        "state_normalization": {"type": ["string", "null"]},
        "coupling_convention": {"type": ["string", "null"]},
        "index_positioning": {"type": ["string", "null"]},
        "time_ordering": {"type": ["string", "null"]},
        "commutation_convention": {"type": ["string", "null"]},
        "levi_civita_sign": {"type": ["string", "null"]},
        "generator_normalization": {"type": ["string", "null"]},
        "covariant_derivative_sign": {"type": ["string", "null"]},
        "gamma_matrix_convention": {"type": ["string", "null"]},
        "creation_annihilation_order": {"type": ["string", "null"]},
        "custom_conventions": {"type": "object", "additionalProperties": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "approximations": {
      "type": "array",
      "default": [],
      "description": "Active approximations and their validity ranges.",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique approximation identifier."
          },
          "name": {
            "type": "string",
            "description": "Human-readable name (e.g., 'Born approximation')."
          },
          "parameter": {
            "type": "string",
            "description": "Small parameter or expansion variable."
          },
          "valid_when": {
            "type": "string",
            "description": "Condition under which the approximation holds."
          },
          "breaks_when": {
            "type": "string",
            "description": "Condition under which the approximation fails."
          },
          "order": {
            "type": "integer",
            "default": 1,
            "description": "Order of the approximation (e.g., leading order = 1)."
          }
        },
        "required": ["id", "name", "parameter", "valid_when", "breaks_when"]
      }
    },
    "intermediate_results": {
      "type": "array",
      "default": [],
      "description": "Intermediate calculation results with dependency tracking.",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique result identifier."
          },
          "equation": {
            "type": "string",
            "description": "The equation or expression (LaTeX)."
          },
          "description": {
            "type": "string",
            "description": "What this result represents."
          },
          "units": {
            "type": "string",
            "description": "Physical units or dimensions."
          },
          "validity": {
            "type": "string",
            "description": "Regime where this result is valid."
          },
          "phase": {
            "type": ["string", "null"],
            "description": "GPD phase in which this result was produced."
          },
          "depends_on": {
            "type": "array",
            "items": { "type": "string" },
            "default": [],
            "description": "IDs of results this depends on."
          },
          "verified": {
            "type": "boolean",
            "default": false,
            "description": "Whether this result has been verified."
          }
        },
        "required": ["id", "equation", "description", "units", "validity"]
      }
    },
    "open_questions": {
      "type": "array",
      "default": [],
      "description": "Unresolved physics questions for this branch.",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique question identifier."
          },
          "question": {
            "type": "string",
            "description": "The open question."
          },
          "priority": {
            "type": "string",
            "description": "Priority level (e.g., critical, high, medium, low)."
          },
          "context": {
            "type": "string",
            "description": "Context for why this question matters."
          }
        },
        "required": ["id", "question", "priority", "context"]
      }
    },
    "active_calculations": {
      "type": "array",
      "default": [],
      "description": "Calculations currently in progress on this branch.",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique calculation identifier."
          },
          "description": {
            "type": "string",
            "description": "What is being calculated."
          },
          "status": {
            "type": "string",
            "description": "Current status (e.g., in_progress, blocked, complete)."
          },
          "approach": {
            "type": "string",
            "description": "Method or approach being used."
          }
        },
        "required": ["id", "description", "status", "approach"]
      }
    },
    "decisions": {
      "type": "array",
      "default": [],
      "description": "Physics decisions made on this branch with rationale.",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique decision identifier."
          },
          "decision": {
            "type": "string",
            "description": "The decision that was made."
          },
          "rationale": {
            "type": "string",
            "description": "Why this decision was made."
          },
          "phase": {
            "type": ["string", "null"],
            "description": "GPD phase in which this decision was made."
          },
          "alternatives_considered": {
            "type": "array",
            "items": { "type": "string" },
            "default": [],
            "description": "Alternatives that were considered."
          }
        },
        "required": ["id", "decision", "rationale"]
      }
    },
    "pending_todos": {
      "type": "array",
      "default": [],
      "description": "Tasks remaining for this branch.",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique todo identifier."
          },
          "task": {
            "type": "string",
            "description": "Description of the task."
          },
          "priority": {
            "type": "string",
            "description": "Priority level (e.g., critical, high, medium, low)."
          },
          "blocked_by": {
            "type": "string",
            "default": "",
            "description": "ID of what blocks this todo (empty if unblocked)."
          }
        },
        "required": ["id", "task", "priority"]
      }
    },
    "blockers": {
      "type": "array",
      "default": [],
      "description": "Active blockers preventing progress.",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique blocker identifier."
          },
          "description": {
            "type": "string",
            "description": "What is blocked and why."
          },
          "severity": {
            "type": "string",
            "description": "Severity level (e.g., critical, high, medium, low)."
          },
          "blocked_by": {
            "type": "string",
            "description": "ID or description of the upstream dependency causing the block."
          }
        },
        "required": ["id", "description", "severity"]
      }
    },
    "propagated_uncertainties": {
      "type": "array",
      "default": [],
      "description": "Tracked uncertainty propagation across calculations.",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique uncertainty identifier."
          },
          "quantity": {
            "type": "string",
            "description": "The physical quantity being tracked."
          },
          "value": {
            "type": ["string", "null"],
            "description": "Current best-estimate value."
          },
          "uncertainty": {
            "type": ["string", "null"],
            "description": "Uncertainty magnitude or expression."
          },
          "phase": {
            "type": ["string", "null"],
            "description": "GPD phase in which this uncertainty was computed."
          },
          "method": {
            "type": ["string", "null"],
            "description": "Method used for uncertainty propagation."
          }
        },
        "required": ["id", "quantity"]
      }
    },
    "gpd_position": {
      "type": "object",
      "description": "Current position in the GPD research workflow.",
      "properties": {
        "current_phase": {
          "type": ["string", "null"],
          "description": "Phase identifier (e.g., '1', '2.3')."
        },
        "current_phase_name": {
          "type": ["string", "null"],
          "description": "Human-readable phase name."
        },
        "current_plan": {
          "type": ["string", "null"],
          "description": "Active plan within the current phase."
        },
        "status": {
          "type": "string",
          "default": "idle",
          "description": "Workflow status (e.g., idle, active, paused, complete)."
        },
        "progress_percent": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100,
          "default": 0,
          "description": "Overall progress within the current phase (0-100)."
        }
      }
    },
    "gpd": {
      "type": "object",
      "description": "Typed GPD orchestration state shared across the campaign DAG.",
      "additionalProperties": false,
      "properties": {
        "phase": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "id": {
              "type": ["string", "null"],
              "description": "Phase identifier (for example '2' or '4.1')."
            },
            "name": {
              "type": ["string", "null"],
              "description": "Human-readable phase name."
            },
            "status": {
              "type": "string",
              "default": "idle",
              "description": "Phase execution status."
            }
          }
        },
        "branch_intent": {
          "type": ["object", "null"],
          "description": "Machine-readable description of how this branch or delegated subagent should proceed.",
          "additionalProperties": false,
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["in_process", "terminal"],
              "description": "Whether the spawn is in-process delegation or terminal DAG branching."
            },
            "parent_goal": {
              "type": "string",
              "description": "What the parent actor is trying to accomplish."
            },
            "variant_label": {
              "type": "string",
              "description": "Short label for this branch variant."
            },
            "variant_role": {
              "type": ["string", "null"],
              "description": "Optional role or specialization assigned to the branch."
            },
            "strategy_summary": {
              "type": "string",
              "description": "Concise operational summary of the branch's strategy."
            },
            "top_k": {
              "type": ["integer", "null"],
              "minimum": 1,
              "description": "Configured branching budget for this move when relevant."
            },
            "diversity_axes": {
              "type": "array",
              "default": [],
              "items": { "type": "string" },
              "description": "Axes along which this branch differs from siblings."
            },
            "downstream_action_hint": {
              "type": ["string", "null"],
              "description": "Suggested downstream action or workflow for this branch."
            },
            "receives_results_back": {
              "type": "boolean",
              "default": false,
              "description": "Whether the parent actor expects this branch to return a result directly."
            },
            "rationale": {
              "type": "string",
              "description": "Why this branch exists."
            }
          },
          "required": [
            "mode",
            "parent_goal",
            "variant_label",
            "strategy_summary",
            "receives_results_back",
            "rationale"
          ]
        },
        "decision_log": {
          "type": "array",
          "default": [],
          "description": "Typed decision log entries for branch-level orchestration choices.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string" },
              "summary": { "type": "string" },
              "rationale": { "type": "string" },
              "phase": { "type": ["string", "null"] },
              "source": { "type": ["string", "null"] }
            },
            "required": ["id", "summary", "rationale"]
          }
        },
        "verification_focus": {
          "type": "array",
          "default": [],
          "description": "Verification work items the branch should prioritize next.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string" },
              "check": { "type": "string" },
              "priority": { "type": "string" },
              "rationale": { "type": "string" }
            },
            "required": ["id", "check", "priority", "rationale"]
          }
        },
        "required_tools": {
          "type": "array",
          "default": [],
          "description": "Tools the branch expects or requires for successful execution.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "purpose": { "type": "string" },
              "required": { "type": "boolean", "default": true }
            },
            "required": ["name", "purpose", "required"]
          }
        },
        "shared_claims": {
          "type": "array",
          "default": [],
          "description": "Cross-branch claims and findings that may be reused or challenged downstream.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string" },
              "claim": { "type": "string" },
              "status": { "type": "string" },
              "confidence": {
                "type": "number",
                "minimum": 0.0,
                "maximum": 1.0
              },
              "published_claim_id": {
                "type": ["string", "null"],
                "description": "External identifier when this claim is published to a shared store."
              }
            },
            "required": ["id", "claim", "status", "confidence"]
          }
        },
        "open_questions": {
          "type": "array",
          "default": [],
          "description": "Typed open questions tracked at the GPD orchestration level.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string" },
              "question": { "type": "string" },
              "priority": { "type": "string" },
              "context": { "type": "string" }
            },
            "required": ["id", "question", "priority", "context"]
          }
        }
      }
    }
  },
  "default": {
    "convention_lock": {},
    "approximations": [],
    "intermediate_results": [],
    "open_questions": [],
    "active_calculations": [],
    "decisions": [],
    "pending_todos": [],
    "blockers": [],
    "propagated_uncertainties": [],
    "gpd_position": {
      "current_phase": null,
      "current_phase_name": null,
      "current_plan": null,
      "status": "idle",
      "progress_percent": 0
    },
    "gpd": {
      "phase": {
        "id": null,
        "name": null,
        "status": "idle"
      },
      "branch_intent": null,
      "decision_log": [],
      "verification_focus": [],
      "required_tools": [],
      "shared_claims": [],
      "open_questions": []
    }
  }
}
